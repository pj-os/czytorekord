# Analityka PostHog (custom events: miasta, udostępnienia, pobrania).
# Załóż darmowy projekt na https://eu.posthog.com (region EU → RODO),
# skopiuj "Project API Key" i ustaw w Vercel → Settings → Environment Variables.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Opcjonalnie (domyślnie host EU):
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
